---
---

<section id="hero" class="hero-section">
  <div class="hero-image-container">
    <img src="/images/hero.png" alt="ElektroTouch Experte bei der Arbeit" class="hero-img" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content-wrapper">
    <div class="hero-content animate-in">
      <span class="section-label">📍 Ihr Elektriker im Kreis Mettmann</span>
      <h1 class="hero-title">
        Moderne Elektrotechnik.<br />
        <span class="hero-accent">Persönlich & Nah.</span>
      </h1>
      <p class="hero-description">
        Willkommen bei ElektroTouch. Wir sind Ihr zuverlässiger Partner für Industrie, Gewerbe und Ihr Zuhause. Professioneller Service direkt aus der Nachbarschaft.
      </p>

      <div class="hero-cta">
        <a href="tel:+491629554175" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Jetzt anrufen
        </a>
        <a href="#leistungen" class="btn-secondary">Unsere Leistungen</a>
      </div>
      
      <div class="hero-trust">
         <span class="trust-item">✅ Meisterhaft & Sicher</span>
         <span class="trust-item">✅ Schnell vor Ort</span>
         <span class="trust-item">✅ Faire Preise</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    background: #fff;
  }

  .hero-image-container {
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, #FFFFFF 20%, rgba(255,255,255,0.7) 40%, rgba(255,255,255,0) 100%);
  }

  .hero-content-wrapper {
    position: relative;
    z-index: 10;
  }

  .hero-content {
    max-width: 600px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .hero-accent {
    color: var(--color-secondary);
  }

  .hero-description {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .hero-trust {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    color: var(--color-text-muted);
    font-weight: 600;
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .hero-image-container {
      width: 100%;
      opacity: 0.2;
    }
    .hero-overlay {
      background: #FFFFFF;
      opacity: 0.8;
    }
    .hero-section {
      text-align: center;
      justify-content: center;
    }
    .hero-cta {
      justify-content: center;
    }
    .hero-trust {
      justify-content: center;
    }
  }
</style>
