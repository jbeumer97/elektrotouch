---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="logo">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        Elektro<strong>Touch</strong>
      </div>
      <p class="footer-desc">Ihr regionaler Elektromeister für den Kreis Mettmann. Professionell, sicher und für Sie da.</p>
    </div>

    <div class="footer-links">
      <h4 class="footer-title">Navigation</h4>
      <nav aria-label="Footer Nav">
        <a href="#hero">Start</a>
        <a href="#leistungen">Leistungen</a>
        <a href="#ueber-uns">Über uns</a>
        <a href="#kontakt">Kontakt</a>
      </nav>
    </div>

    <div class="footer-contact">
      <h4 class="footer-title">Kontakt</h4>
      <p>📍 Kreis Mettmann & Umgebung</p>
      <p>📞 +49 162 9554175</p>
      <p>✉️ info@elektro-touch.de</p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-inner">
      <p>&copy; {year} ElektroTouch. Alle Rechte vorbehalten.</p>
      <div class="legal">
        <a href="#">Impressum</a>
        <a href="#">Datenschutz</a>
      </div>
    </div>
  </div>

  <!-- Sticky Call Button for Mobile -->
  <a href="tel:+491629554175" class="mobile-sticky-cta">
     📞 Jetzt anrufen
  </a>
</footer>

<style>
  .footer {
    background: #fff;
    padding-top: 5rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .logo svg { color: var(--color-primary); }
  .logo strong { color: var(--color-secondary); }

  .footer-desc {
    color: var(--color-text-muted);
    max-width: 300px;
    line-height: 1.7;
  }

  .footer-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .footer-links nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--color-secondary); }

  .footer-contact p {
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .footer-bottom {
    background: var(--color-bg-alt);
    padding: 1.5rem 0;
  }

  .bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .legal {
    display: flex;
    gap: 2rem;
  }
  .legal a {
    text-decoration: none;
    color: inherit;
  }

  .mobile-sticky-cta {
    display: none;
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #000;
    padding: 1rem 2rem;
    border-radius: 3rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    z-index: 1000;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 3rem; }
    .footer-brand, .footer-links, .footer-contact { text-align: center; }
    .logo { justify-content: center; }
    .footer-desc { margin: 0 auto; }
    .mobile-sticky-cta { display: block; }
    .bottom-inner { flex-direction: column; gap: 1rem; }
  }
</style>
