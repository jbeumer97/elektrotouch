---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow" aria-hidden="true"></div>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="#hero" class="footer-logo" aria-label="ElektroTouch - Zur Startseite">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        Elektro<strong>Touch</strong>
      </a>
      <p class="footer-tagline">Energie für die Zukunft – Elektrotechnik im Kreis Mettmann</p>
    </div>

    <nav class="footer-nav" aria-label="Footer Navigation">
      <h4>Navigation</h4>
      <a href="#leistungen">Leistungen</a>
      <a href="#ueber-uns">Über uns</a>
      <a href="#kontakt">Kontakt</a>
    </nav>

    <div class="footer-contact" aria-label="Kontaktdaten">
      <h4>Kontakt</h4>
      <a href="tel:+491629554175" aria-label="Anrufen: +49 162 9554175">📞 +49 162 9554175</a>
      <a href="mailto:info@elektro-touch.de" aria-label="E-Mail senden">✉️ info@elektro-touch.de</a>
      <a href="https://wa.me/491629554175" target="_blank" rel="noopener" aria-label="WhatsApp schreiben">💬 WhatsApp</a>
      <span>📍 Kreis Mettmann &amp; Umgebung</span>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>Copyright &copy; {year} ElektroTouch. Alle Rechte vorbehalten.</p>
      <div class="footer-legal">
        <a href="/datenschutz">Datenschutz</a>
        <a href="/impressum">Impressum</a>
      </div>
    </div>
  </div>
</footer>

<!-- Sticky mobile CTA bar -->
<div class="mobile-cta-bar" aria-label="Schnellkontakt">
  <a href="tel:+491629554175" class="mobile-cta-btn call" id="mobile-sticky-call" aria-label="Jetzt anrufen">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
