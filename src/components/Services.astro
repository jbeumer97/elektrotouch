---
const services = [
  {
    id: "industrie",
    image: "/images/service-industrie.png",
    title: "Industrie & Anlagen",
    description: "Vor-Ort-Service für Industrieanlagen, Wartung von Motoren & Transformatoren.",
    features: ["Prüfung & Wartung", "Frequenzumrichter", "Anlagenstillstände"]
  },
  {
    id: "gewerbe",
    image: "/images/service-gewerbe.png",
    title: "Gewerbe & Büros",
    description: "DIN-gerechte Beleuchtung, USV-Anlagen, Serverraum-Infrastruktur.",
    features: ["LED-Modernisierung", "Serverräume", "Videoüberwachung"]
  },
  {
    id: "privat",
    image: "/images/service-smarthome.png",
    title: "Smart Home & Privat",
    description: "Gebäudesteuerung, VDE-Prüfberichte und Sicherheit für Ihr Zuhause.",
    features: ["Smart-Home", "VDE-Prüfung", "Fehlersuche"]
  },
  {
    id: "emobilitaet",
    image: "/images/service-emobility.png",
    title: "Wallboxen & E-Mobilität",
    description: "Sichere Ladestationen und Konfiguration für Ihr E-Auto.",
    features: ["Wandladestation", "VDE-konform", "Lastmanagement"]
  }
];
---

<section id="leistungen" class="section-padding services-section">
  <div class="container">
    <div class="section-header animate-in">
      <span class="section-label">Unsere Expertise</span>
      <h2 class="section-title">Alles für Ihre Elektrik</h2>
      <p class="section-subtitle">
        Von der kleinen Reparatur bis zur komplexen Industrieanlage – wir sind Ihr kompetenter Partner im Kreis Mettmann.
      </p>
    </div>

    <div class="grid-with-images">
      {services.map((service, index) => (
        <article class={`card service-card animate-in delay-${index + 1}`}>
          <div class="service-image">
            <img src={service.image} alt={service.title} />
          </div>
          <div class="service-body">
            <h3 class="service-title">{service.title}</h3>
            <p class="service-description">{service.description}</p>
            <ul class="service-features">
              {service.features.map((f) => (
                <li><span>✓</span> {f}</li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: var(--color-bg-alt);
  }

  .section-header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .section-subtitle {
     margin: 0 auto;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: none;
    box-shadow: var(--shadow-md);
  }

  .service-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .service-card:hover .service-image img {
    transform: scale(1.05);
  }

  .service-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .service-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .service-description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .service-features {
    list-style: none;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .service-features li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .service-features li span {
    color: var(--color-primary-dark);
    margin-right: 0.5rem;
  }
</style>
