---
---

<section id="kontakt" class="section-padding contact-section">
  <div class="container contact-container">
    <div class="contact-card-main animate-in">
       <div class="contact-header">
          <span class="section-label">Kontakt</span>
          <h2 class="section-title">Fragen? Wir helfen gern.</h2>
          <p class="section-subtitle">Schicken Sie uns eine Nachricht oder rufen Sie direkt an – wir freuen uns auf Ihr Projekt.</p>
       </div>

       <form id="contact-form" class="bright-form">
          <div class="form-grid">
             <div class="form-group">
                <label for="name">Ihr Name</label>
                <input type="text" id="name" name="name" placeholder="Max Mustermann" required />
             </div>
             <div class="form-group">
                <label for="email">E-Mail Adresse</label>
                <input type="email" id="email" name="email" placeholder="max@beispiel.de" required />
             </div>
          </div>
          <div class="form-group">
             <label for="message">Wie können wir helfen?</label>
             <textarea id="message" name="message" rows="4" placeholder="Schreiben Sie uns Ihr Anliegen..." required></textarea>
          </div>
          <button type="submit" class="btn-primary" style="width: 100%;">Nachricht senden</button>
          
          <div id="form-msg" class="form-feedback"></div>
       </form>
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-bg-alt);
  }

  .contact-container {
    max-width: 800px !important;
  }

  .contact-card-main {
    background: #fff;
    padding: 3.5rem;
    border-radius: 2rem;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border);
  }

  .contact-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
  }

  input, textarea {
    padding: 1rem;
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    font-size: 1rem;
    transition: all 0.2s;
  }

  input:focus, textarea:focus {
    border-color: var(--color-secondary);
    outline: none;
    box-shadow: 0 0 0 4px rgba(30, 64, 175, 0.1);
  }

  .form-feedback {
    margin-top: 1.5rem;
    text-align: center;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .form-grid { grid-template-columns: 1fr; }
    .contact-card-main { padding: 2rem; }
  }
</style>
